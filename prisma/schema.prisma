generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ── UTILISATEURS ──────────────────────────────────────────────

model User {
  id          Int       @id @default(autoincrement())
  uuid        String    @unique @default(cuid())
  matricule   String
  firstName   String
  lastName    String
  email       String    @unique
  login       String?   @unique
  password    String
  role        UserRole  @default(AGENT)
  isActive    Boolean   @default(true)
  avatar      String?
  phone       String?
  mobile      String?
  fonction       String?
  idNumber       String?
  civilite       CiviliteType?
  statutConjugal StatutConjugalType?
  hireDate       DateTime?
  cnpsNumber     String?
  residence      String?
  // Préférence de thème graphique : DEFAULT | AFRIKIMMO | DARK_GOLD
  theme       String    @default("DEFAULT")
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  activities           CrmActivity[]
  conventions          Convention[]    @relation("AgentConventions")
  notes                Note[]
  archivedEntities     ArchiveRecord[] @relation("ArchivedBy")
  restoredEntities     ArchiveRecord[] @relation("RestoredBy")
  commissions          Commission[]    @relation("UserCommissions")
  commissionsPaid      Commission[]    @relation("CommissionPaidBy")
  commissionsCancelled Commission[]    @relation("CommissionCancelledBy")
  treasuryOperations   TreasuryOperation[] @relation("TreasuryCreatedBy")
  linkedBankAccounts   BankAccount[]       @relation("BankAccountLinkedUser")
  uploadedDocuments    Document[]          @relation("DocumentUploadedBy")
  linkedDocuments      Document[]          @relation("DocumentLinkedUser")
  documentAuditLogs    DocumentAuditLog[]  @relation("DocumentAuditUser")
  managedBudgetLines   BudgetLine[]        @relation("BudgetLineManager")
  closedBudgets        Budget[]            @relation("BudgetClosedBy")
  assignedProspects    Prospect[]          @relation("ProspectAssignedTo")
  createdProspects     Prospect[]          @relation("ProspectCreatedBy")
  assignedClients      Client[]            @relation("ClientAssignedTo")
  attestationsEmitted  Attestation[]       @relation("AttestationEmittedBy")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  ACCOUNTANT
  ASSISTANTE_DIRECTION
  AGENT
  READONLY
}

// ── PROSPECTS ─────────────────────────────────────────────────

model Prospect {
  id           Int            @id @default(autoincrement())
  uuid         String         @unique @default(cuid())
  firstName    String
  lastName     String
  email        String?
  phone        String?
  mobile       String?
  source       ProspectSource @default(PROSPECTION)
  status       ProspectStatus @default(NOUVEAU)
  budget       Decimal?       @db.Decimal(15, 2)
  notes        String?        @db.Text
  assignedToId Int?
  createdById  Int?
  convertedAt  DateTime?
  clientId     Int?           @unique
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime?

  client     Client?       @relation(fields: [clientId], references: [id])
  assignedTo User?         @relation("ProspectAssignedTo", fields: [assignedToId], references: [id])
  createdBy  User?         @relation("ProspectCreatedBy",  fields: [createdById],  references: [id])
  activities CrmActivity[]
  tags       ProspectTag[]
  documents  Document[]
}

enum ProspectSource {
  SITE_WEB_AFRIKIMMO
  RECOMMENDATION
  TELEPHONE
  RESEAUX_SOCIAUX
  EMAIL
  CONTACT_PERSONNEL
  AUTRE
  PROSPECTION
}

enum ProspectStatus {
  NOUVEAU
  CONTACTE
  QUALIFIE
  ENVOI_PROPOSITION
  NEGOCIATION_EN_COURS
  CONVERTI
  PERDU
}

// ── CLIENTS ───────────────────────────────────────────────────

model Client {
  id                   Int        @id @default(autoincrement())
  uuid                 String     @unique @default(cuid())
  type                 ClientType @default(INDIVIDUEL)
  firstName            String?
  lastName             String?
  civilite             CiviliteType       @default(MONSIEUR)
  statutConjugal       StatutConjugalType @default(CELIBATAIRE)
  entreprise           String?
  registre_de_commerce String?
  compte_contribuable  String?
  email                String?
  phone                String?
  mobile               String?
  address              String?
  city                 String?
  postalCode           String?
  country              String     @default("CI")
  nationality          String?
  birthDate            DateTime?
  birthPlace           String?
  idNumber             String?
  idTypeId             Int?
  fatherFirstName      String?
  fatherLastName       String?
  motherFirstName      String?
  motherLastName       String?
  notes                String?    @db.Text
  isActive             Boolean      @default(true)
  status               ClientStatus @default(ACTIF)
  // Affectation : un client peut être suivi par un utilisateur interne ET
  // apporté par un référent externe (BusinessReferrer) ; les deux coexistent.
  assignedToId         Int?
  referrerId           Int?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  deletedAt            DateTime?

  prospect             Prospect?
  assignedTo           User?             @relation("ClientAssignedTo", fields: [assignedToId], references: [id])
  referrer             BusinessReferrer? @relation("ClientReferrer", fields: [referrerId], references: [id])
  idType               IdDocumentType?   @relation("ClientIdType", fields: [idTypeId], references: [id])
  conventions          Convention[]      @relation("ConventionClient")
  secondaryConventions Convention[]      @relation("ConventionSecondaryClient")
  documents            Document[]
  activities         CrmActivity[]
  invoices           Invoice[]
  terrains           Terrain[]
  properties         Property[]    @relation("ClientProperties")
  attestations          Attestation[] @relation("AttestationClient")
  attestationsSecondary Attestation[] @relation("AttestationSecondaryClient")
  projects             Project[]
}

enum ClientType {
  INDIVIDUEL
  ENTREPRISE
}

enum ClientStatus {
  ACTIF
  INACTIF
  VIP
  SUSPENDU
}

enum CiviliteType {
  MONSIEUR
  MADAME
  MADEMOISELLE
}

enum StatutConjugalType {
  CELIBATAIRE
  MARIEE
  CONCUBINAGE
}

// ── PROPRIÉTAIRES ─────────────────────────────────────────────

model Owner {
  id                  Int        @id @default(autoincrement())
  uuid                String     @unique @default(cuid())
  type                ClientType @default(INDIVIDUEL)
  // Particulier
  firstName           String?
  lastName            String?
  nationality         String?    // Nationalité (particulier)
  idNumber            String?    // Numéro pièce d'identité (particulier)
  idTypeId            Int?       // Type de pièce d'identité (particulier)
  // Entreprise
  companyName         String?
  registreCommerce    String?    // Numéro registre de commerce
  legalRepFirstName   String?    // Prénom représentant légal
  legalRepLastName    String?    // Nom représentant légal
  legalRepPhone       String?    // Contact représentant légal
  legalRepIdNumber    String?    // Numéro pièce d'identité représentant légal
  legalRepIdTypeId    Int?       // Type de pièce d'identité du représentant légal
  // Commun
  email               String?
  phone               String?
  mobile              String?
  address             String?
  city                String?
  postalCode          String?
  country             String     @default("CI")
  bankIban            String?
  bankBic             String?
  compte_contribuable String?
  notes               String?    @db.Text
  isActive            Boolean    @default(true)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  deletedAt           DateTime?

  properties Property[]
  terrains   Terrain[]
  documents  Document[]
  activities CrmActivity[]
  projects   Project[]
  idType         IdDocumentType? @relation("OwnerIdType",         fields: [idTypeId],         references: [id])
  legalRepIdType IdDocumentType? @relation("OwnerLegalRepIdType", fields: [legalRepIdTypeId], references: [id])
}

// ── LOTISSEMENTS ───────────────────────────────────────────────

model Lotissement {
  id              Int               @id @default(autoincrement())
  uuid            String            @unique @default(cuid())
  reference       String            @unique  // Ex: LOT-2024-0001
  nom             String
  commune         String?
  quartier        String?
  ville           String
  pays            String            @default("CI")
  surface         Decimal?          @db.Decimal(12, 2)  // Surface totale en m²
  nombreParcelles Int?
  promoteur       String?
  statut          LotissementStatus @default(EN_COURS_LOTISSEMENT)
  // Titre administratif sollicité (référentiel paramétrable) et numéro du
  // titre obtenu lorsqu'il est délivré.
  titleTypeId     Int?
  titleNumber     String?
  description     String?           @db.Text
  latitude        Float?
  longitude       Float?
  // Frais de démarches ACD : montant standard applicable lorsqu'un client confie
  // les démarches ACD à l'entreprise sur un terrain de ce lotissement. Sert de
  // pré-remplissage sur chaque terrain — la valeur retenue reste modifiable au
  // niveau du terrain (négociation, remise…).
  fraisDemarchesAcdStandard Decimal? @db.Decimal(15, 2)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?

  terrains            Terrain[]
  documents           Document[]
  activities          CrmActivity[]
  projects            Project[]
  treasuryOperations  TreasuryOperation[]
  titleType           LotissementTitleType? @relation(fields: [titleTypeId], references: [id])
}

enum LotissementStatus {
  EN_COURS_LOTISSEMENT
  EN_COURS
  OUVERT
  PARTIELLEMENT_VENDU
  COMPLET
  FERME
}

// ── PROGRAMMES IMMOBILIERS ─────────────────────────────────────

/// Programme immobilier : opération de promotion regroupant des biens
/// (et éventuellement des terrains) mis à la vente ou en location.
model ProgrammeImmobilier {
  id                  Int             @id @default(autoincrement())
  uuid                String          @unique @default(cuid())
  reference           String          @unique  // Ex: PROG-2026-0001
  nom                 String
  type                ProgrammeType   @default(RESIDENTIEL)
  promoteur           String?
  commune             String?
  quartier            String?
  ville               String
  pays                String          @default("CI")
  surface             Decimal?        @db.Decimal(12, 2)  // Surface totale en m²
  nombreLogements     Int?
  dateDebut           DateTime?       // Date de démarrage du programme
  dateLivraisonPrevue DateTime?       // Date de livraison prévisionnelle
  statut              ProgrammeStatus @default(EN_PROJET)
  description         String?         @db.Text
  latitude            Float?
  longitude           Float?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  deletedAt           DateTime?

  properties          Property[]
  terrains            Terrain[]
  documents           Document[]
  activities          CrmActivity[]
  projects            Project[]
  treasuryOperations  TreasuryOperation[]
}

enum ProgrammeType {
  RESIDENTIEL
  COMMERCIAL
  MIXTE
}

enum ProgrammeStatus {
  EN_PROJET
  EN_CONSTRUCTION
  EN_COMMERCIALISATION
  LIVRE
  CLOTURE
}

// ── TERRAINS ───────────────────────────────────────────────────

model Terrain {
  id             Int           @id @default(autoincrement())
  uuid           String        @unique @default(cuid())
  reference      String        @unique  // Ex: TER-2024-0001
  lotissementId  Int
  programmeId    Int?          // Programme immobilier d'origine (optionnel)
  ownerId        Int?
  clientId       Int?          // Attributaire (client à qui le terrain est attribué)
  numeroIlot     String?       // Numéro d'îlot
  numeroParcelle String?       // Numéro de parcelle/lot
  statut         TerrainStatus @default(DISPONIBLE)
  surface        Decimal?      @db.Decimal(12, 2)  // m²
  prixVente      Decimal?      @db.Decimal(15, 2)
  viabilise      Boolean       @default(false)
  numeroADU                    String?  // Numéro ADU
  numeroAttestationAttribution String?  // Numéro attestation d'attribution
  numeroAttestationCession     String?  // Numéro attestation de cession
  numeroDM                     String?  // Numéro décision de morcellement
  titreFoncier                 String?  // Numéro titre foncier
  numeroACD                    String?  // Numéro arrêté de concession définitive
  description    String?       @db.Text
  latitude       Float?
  longitude      Float?
  // Frais de démarches ACD — option client : prise en charge des démarches ACD
  // par l'entreprise. Indépendant du prix du terrain et des frais de dossier.
  acdDemarchesEnabled          Boolean   @default(false)   // Le client a opté pour la prise en charge
  acdDemarchesAmount           Decimal?  @db.Decimal(15, 2) // Montant retenu (pré-rempli depuis Lotissement, modifiable)
  acdDemarchesStartDate        DateTime?                    // Date de la 1ʳᵉ échéance (ou paiement comptant si cash)
  acdDemarchesInstallmentCount Int?                         // 1 = comptant, N > 1 = échelonné (cadence mensuelle)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  lotissement Lotissement          @relation(fields: [lotissementId], references: [id])
  programme   ProgrammeImmobilier? @relation(fields: [programmeId], references: [id])
  owner       Owner?               @relation(fields: [ownerId], references: [id])
  client      Client?              @relation(fields: [clientId], references: [id])
  documents   Document[]
  photos      TerrainPhoto[]
  activities  CrmActivity[]
  conventionLinks ConventionTerrain[]
  attestations Attestation[]
  invoices    Invoice[]
  projects    Project[]
}

enum TerrainStatus {
  DISPONIBLE
  RESERVE
  VENDU
  SOUS_OPTION
}

model TerrainPhoto {
  id        Int      @id @default(autoincrement())
  terrainId Int
  path      String
  caption   String?
  isPrimary Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  terrain Terrain @relation(fields: [terrainId], references: [id])
}

// ── BIENS IMMOBILIERS ─────────────────────────────────────────

model Property {
  id            Int                @id @default(autoincrement())
  uuid          String             @unique @default(cuid())
  reference     String             @unique
  type          PropertyType
  status        PropertyStatus     @default(DISPONIBLE)
  // Origine du bien : un bien provient soit d'un propriétaire, soit d'un
  // programme immobilier (exclusif). Les deux champs peuvent être nuls.
  ownerId       Int?
  programmeId   Int?
  // Client rattaché au bien : présent uniquement lorsque le bien n'est pas
  // DISPONIBLE (réservé, sous option, vendu, en location…). Vidé automatiquement
  // au retour à DISPONIBLE.
  clientId      Int?
  address       String
  addressLine2  String?
  city          String
  postalCode    String
  country       String             @default("CI")
  latitude      Float?
  longitude     Float?
  surface       Decimal?           @db.Decimal(10, 2)
  surfaceCarrez Decimal?           @db.Decimal(10, 2)
  rooms         Int?
  bedrooms      Int?
  bathrooms     Int?
  floor         Int?
  totalFloors   Int?
  buildYear     Int?
  condition     PropertyCondition?
  garage        String?
  cuisine       String?
  terrasseBalcon String?
  rentPrice     Decimal?           @db.Decimal(15, 2)
  salePrice     Decimal?           @db.Decimal(15, 2)
  charges       Decimal?           @db.Decimal(15, 2)
  taxeFonciere  Decimal?           @db.Decimal(15, 2)
  description   String?            @db.Text
  amenities     Json?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  deletedAt     DateTime?

  owner       Owner?               @relation(fields: [ownerId], references: [id])
  programme   ProgrammeImmobilier? @relation(fields: [programmeId], references: [id])
  client      Client?              @relation("ClientProperties", fields: [clientId], references: [id])
  conventionLinks ConventionProperty[]
  documents   Document[]
  photos      PropertyPhoto[]
  activities  CrmActivity[]
  attestations Attestation[]
}

enum PropertyType {
  APARTEMENT
  DUPLEX
  VILLA
  STUDIO
  BUREAU
  PARKING
  AUTRE
}

enum PropertyStatus {
  DISPONIBLE
  RESERVE
  SOUS_OPTION
  VENDU
  EN_LOCATION
  EN_RENOVATION
  INDISPONIBLE
}

enum PropertyCondition {
  NOUVEAU
  EXCELLENT
  BON
  MOYEN
  MAUVAIS
}

model PropertyPhoto {
  id         Int      @id @default(autoincrement())
  propertyId Int
  path       String
  caption    String?
  isPrimary  Boolean  @default(false)
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id])
}

// ── CONVENTIONS ───────────────────────────────────────────────

model Convention {
  id                   Int              @id @default(autoincrement())
  uuid                 String           @unique @default(cuid())
  reference            String           @unique
  type                 ConventionType
  status               ConventionStatus @default(BROUILLON)
  assetType            ConventionAssetType @default(PROPERTY)
  clientId             Int
  secondaryClientId    Int?
  parentConventionId   Int?
  amendmentType        ConventionAmendmentType?
  souscriptionType     ConventionSouscriptionType?
  agentId              Int?
  startDate            DateTime
  endDate              DateTime?
  signedAt             DateTime?
  rentAmount           Decimal?         @db.Decimal(15, 2)
  saleAmount           Decimal?         @db.Decimal(15, 2)
  apportInitial        Decimal?         @db.Decimal(15, 2)
  deposit              Decimal?         @db.Decimal(15, 2)
  agencyFees           Decimal?         @db.Decimal(15, 2)
  charges              Decimal?         @db.Decimal(15, 2)
  // Frais d'ouverture de dossier facturés au client à la signature.
  fraisOuvertureDossier Decimal?        @db.Decimal(15, 2)
  paymentDay           Int?
  paymentMethod        PaymentMethod    @default(ESPECE)
  paymentModalites     PaymentModalites @default(CASH)
  installmentCount     Int?
  installmentAmount    Decimal?         @db.Decimal(15, 2)
  firstInstallmentDate DateTime?
  lastInstallmentDate  DateTime?
  indexType            String?
  lastRevisionAt       DateTime?
  notes                String?          @db.Text
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  deletedAt            DateTime?

  properties       ConventionProperty[]
  terrains         ConventionTerrain[]
  client           Client         @relation("ConventionClient", fields: [clientId], references: [id])
  secondaryClient  Client?        @relation("ConventionSecondaryClient", fields: [secondaryClientId], references: [id])
  agent            User?          @relation("AgentConventions", fields: [agentId], references: [id])
  // Convention initiale/précédente (pour les avenants et résiliations)
  parentConvention Convention?    @relation("ConventionAmendments", fields: [parentConventionId], references: [id])
  amendments       Convention[]   @relation("ConventionAmendments")
  invoices     Invoice[]
  documents    Document[]
  activities   CrmActivity[]
  installments SaleInstallment[]
  commissions  Commission[]
  attestations Attestation[]
}

// Liaison Convention ↔ Bien immobilier (une convention peut couvrir plusieurs biens).
model ConventionProperty {
  conventionId Int
  propertyId   Int
  order        Int      @default(0)
  createdAt    DateTime @default(now())

  convention Convention @relation(fields: [conventionId], references: [id], onDelete: Cascade)
  property   Property   @relation(fields: [propertyId], references: [id])

  @@id([conventionId, propertyId])
  @@index([propertyId])
}

// Liaison Convention ↔ Terrain (une convention peut couvrir plusieurs terrains).
model ConventionTerrain {
  conventionId Int
  terrainId    Int
  order        Int      @default(0)
  createdAt    DateTime @default(now())

  convention Convention @relation(fields: [conventionId], references: [id], onDelete: Cascade)
  terrain    Terrain    @relation(fields: [terrainId], references: [id])

  @@id([conventionId, terrainId])
  @@index([terrainId])
}

enum ConventionType {
  RENTAL_UNFURNISHED
  RENTAL_FURNISHED
  SALE
  MANAGEMENT
  COMMERCIAL_LEASE
  SOUSCRIPTION
  AVENANT
  RESILIATION
}

enum ConventionAssetType {
  PROPERTY
  TERRAIN
}

enum ConventionAmendmentType {
  PROLONGATION_DELAI
  TRANSFERT_PROPRIETE
  TRANSFERT_SITE
}

// Sous-type d'une convention de souscription (rempli quand type === SOUSCRIPTION).
enum ConventionSouscriptionType {
  STANDARD            // Convention de souscription
  AVEC_ACD            // Convention de souscription avec ACD
  FINANCEMENT_PROJET  // Convention de financement sur projet
}

// Modèle de convention enrichi (texte enrichi HTML : en-tête, corps, pied de page)
model ConventionTemplate {
  id        Int          @id @default(autoincrement())
  uuid      String       @unique @default(cuid())
  name      String
  type      ConventionType
  // Nature spécifique (optionnelle) — laisser vide pour un modèle générique
  // couvrant toutes les natures de ce type de convention.
  amendmentType    ConventionAmendmentType?
  souscriptionType ConventionSouscriptionType?
  // En-tête monobloc — texte et/ou image. Toute image insérée occupe 100 %
  // de la largeur du bloc (cf. CSS du rendu PDF). La largeur du bloc et sa
  // hauteur sont configurables.
  header       String? @db.LongText
  headerWidth  Int     @default(100)
  headerHeight Int     @default(140)
  body        String     @db.LongText
  footer      String?    @db.LongText
  footerWidth  Int       @default(100)
  footerHeight Int       @default(140)
  // Couleur de fond du pied de page (hex `#rrggbb` ou `transparent`).
  // `NULL` ⇒ valeur par défaut historique (`#dc2626`).
  footerBgColor String?  @db.VarChar(20)
  // Bloc « Fin du document » — inséré à la suite du corps (signatures,
  // mentions légales finales…). Mêmes contrôles que le pied de page :
  // largeur en %, hauteur en px, couleur de fond optionnelle.
  endOfDocument        String?  @db.LongText
  endOfDocumentWidth   Int      @default(100)
  endOfDocumentHeight  Int      @default(140)
  endOfDocumentBgColor String?  @db.VarChar(20)
  isActive  Boolean      @default(true)
  isDefault Boolean      @default(false)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  deletedAt DateTime?
}

enum ConventionStatus {
  BROUILLON
  ACTIVE
  EXPIRE
  TERMINER
  ANNULE
  ATTENTE_SIGNATURE
}

// ── ATTESTATIONS ──────────────────────────────────────────────

// Type d'attestation émise pour un client depuis le module Conventions.
enum AttestationType {
  ATTRIBUTION         // Attribution d'un terrain à un client
  CESSION             // Cession d'un terrain entre deux clients (cédant ≠ cessionnaire)
  SOLDE               // Solde 0 pour acquisition (frais de dossier inclus)
  TRANSFERT_PROPRIETE // Transfert de propriété sur un bien/terrain déjà cédé
}

// Modèle d'attestation enrichi (texte HTML : en-tête, corps, pied de page).
// Un modèle par défaut peut être défini pour chaque type d'attestation.
model AttestationTemplate {
  id           Int             @id @default(autoincrement())
  uuid         String          @unique @default(cuid())
  name         String
  type         AttestationType
  // En-tête monobloc — texte et/ou image. Toute image insérée occupe 100 %
  // de la largeur du bloc (cf. CSS du rendu PDF). La largeur du bloc et sa
  // hauteur sont configurables.
  header       String? @db.LongText
  headerWidth  Int     @default(100)
  headerHeight Int     @default(140)
  body         String          @db.LongText
  footer       String?         @db.LongText
  footerWidth  Int             @default(100)
  footerHeight Int             @default(140)
  // Couleur de fond du pied de page (hex `#rrggbb` ou `transparent`).
  // `NULL` ⇒ valeur par défaut historique (`#dc2626`).
  footerBgColor String?        @db.VarChar(20)
  // Bloc « Fin du document » — inséré à la suite du corps (signatures,
  // mentions légales finales…). Mêmes contrôles que le pied de page.
  endOfDocument        String?  @db.LongText
  endOfDocumentWidth   Int      @default(100)
  endOfDocumentHeight  Int      @default(140)
  endOfDocumentBgColor String?  @db.VarChar(20)
  isActive     Boolean         @default(true)
  isDefault    Boolean         @default(false)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  deletedAt    DateTime?

  attestations Attestation[]
}

// Attestation émise pour un client. Référence auto ATT-YYYY-NNNN.
// Rattachement optionnel à une convention, un terrain ou un bien.
// Pour une CESSION, secondaryClientId = cédant (différent du clientId/cessionnaire).
model Attestation {
  id                Int             @id @default(autoincrement())
  uuid              String          @unique @default(cuid())
  reference         String          @unique // Ex: ATT-2026-0007
  type              AttestationType
  clientId          Int             // Bénéficiaire (attributaire / cessionnaire / acquéreur)
  secondaryClientId Int?            // Cédant (CESSION) ou ancien propriétaire (TRANSFERT_PROPRIETE)
  terrainId         Int?
  propertyId        Int?
  conventionId      Int?            // Lien optionnel vers la convention d'origine
  templateId        Int?            // Modèle utilisé au moment de l'émission
  emittedAt         DateTime        @default(now())
  emittedById       Int?
  amount            Decimal?        @db.Decimal(15, 2) // Montant (utile pour SOLDE notamment)
  notes             String?         @db.Text
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  deletedAt         DateTime?

  client          Client               @relation("AttestationClient", fields: [clientId], references: [id])
  secondaryClient Client?              @relation("AttestationSecondaryClient", fields: [secondaryClientId], references: [id])
  terrain         Terrain?             @relation(fields: [terrainId], references: [id])
  property        Property?            @relation(fields: [propertyId], references: [id])
  convention      Convention?          @relation(fields: [conventionId], references: [id])
  template        AttestationTemplate? @relation(fields: [templateId], references: [id])
  emittedBy       User?                @relation("AttestationEmittedBy", fields: [emittedById], references: [id])
  documents       Document[]
}

enum PaymentMethod {
  ESPECE
  CHEQUE
  TRANSFERT
  VIREMENT
  MOBILE_MONEY
  NON_DEFINI
}

enum PaymentModalites {
  CASH
  SUR_3_MOIS
  SUR_6_MOIS
  SUR_9_MOIS
  SUR_12_MOIS
  SUR_24_MOIS
  SUR_36_MOIS
  SUR_48_MOIS
  SUR_60_MOIS
  SUR_PLUS_60_MOIS
}

// ── COMPTABILITÉ ──────────────────────────────────────────────

model Invoice {
  id         Int           @id @default(autoincrement())
  uuid       String        @unique @default(cuid())
  reference  String        @unique
  type       InvoiceType
  status       InvoiceStatus @default(BROUILLON)
  clientId     Int?
  conventionId Int?
  // Rattachement direct à un terrain (utilisé pour les factures de
  // frais de démarches ACD : ces frais sont indépendants d'une convention).
  terrainId    Int?
  subtotal     Decimal       @db.Decimal(15, 2)
  taxRate    Decimal       @default(0) @db.Decimal(5, 2)
  taxAmount  Decimal       @db.Decimal(15, 2)
  total      Decimal       @db.Decimal(15, 2)
  issueDate  DateTime      @default(now())
  dueDate    DateTime
  paidAt     DateTime?
  notes      String?       @db.Text
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  deletedAt  DateTime?

  client       Client?           @relation(fields: [clientId], references: [id])
  convention   Convention?       @relation(fields: [conventionId], references: [id])
  terrain      Terrain?          @relation(fields: [terrainId], references: [id])
  items        InvoiceItem[]
  payments     Payment[]
  installments SaleInstallment[]
  activities   CrmActivity[]
  documents    Document[]
}

enum InvoiceType {
  VENTE
  ECHEANCE_VENTE
  FRAIS_AGENCE
  FRAIS_DE_GESTION
  FRAIS_DEMARCHES_ACD
  AVANCE
  CAUTION
  OTHER
}

enum InvoiceStatus {
  BROUILLON
  ENVOYEE
  PAYEE
  PARTIEL
  EN_RETARD
  ANNULEE
}

model InvoiceItem {
  id          Int     @id @default(autoincrement())
  invoiceId   Int
  description String
  quantity    Decimal @db.Decimal(10, 2)
  unitPrice   Decimal @db.Decimal(15, 2)
  total       Decimal @db.Decimal(15, 2)

  invoice Invoice @relation(fields: [invoiceId], references: [id])
}

model Payment {
  id            Int           @id @default(autoincrement())
  invoiceId     Int
  amount        Decimal       @db.Decimal(15, 2)
  method        PaymentMethod
  paidAt        DateTime      @default(now())
  reference     String?
  notes         String?
  bankAccountId Int?          // Compte de trésorerie crédité par ce règlement

  invoice     Invoice      @relation(fields: [invoiceId], references: [id])
  bankAccount BankAccount? @relation(fields: [bankAccountId], references: [id])
}

// ── ÉCHÉANCES DE VENTE ────────────────────────────────────────

model SaleInstallment {
  id                Int               @id @default(autoincrement())
  conventionId      Int
  installmentNumber Int
  dueDate           DateTime
  amount            Decimal           @db.Decimal(15, 2)
  status            InstallmentStatus @default(EN_ATTENTE)
  paidAt            DateTime?
  paymentMethod     PaymentMethod?
  paymentRef        String?
  invoiceId         Int?
  notes             String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  convention Convention    @relation(fields: [conventionId], references: [id])
  invoice    Invoice?      @relation(fields: [invoiceId], references: [id])
  activities CrmActivity[]
}

enum InstallmentStatus {
  EN_ATTENTE
  A_REGLER
  PAYE
  EN_RETARD
  ANNULE
}

// ── MODÈLES DE FACTURE ────────────────────────────────────────
model InvoiceTemplate {
  id          Int                   @id @default(autoincrement())
  uuid        String                @unique @default(cuid())
  name        String
  layout      InvoiceTemplateLayout  @default(CLASSIQUE)
  headerHtml  String?               @db.LongText  // En-tête éditable (HTML)
  footerHtml  String?               @db.LongText  // Pied de page éditable (HTML)
  accentColor String                @default("#1E3A5F")
  isActive    Boolean               @default(true)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
}

enum InvoiceTemplateLayout {
  CLASSIQUE
  MODERNE
  COMPACT
}

// ── CRM & COMMUNICATION ───────────────────────────────────────

model CrmActivity {
  id             Int            @id @default(autoincrement())
  type           ActivityType
  subject        String
  description    String?        @db.Text
  status         ActivityStatus @default(EN_ATTENTE)
  dueDate        DateTime?
  completedAt    DateTime?
  userId         Int?
  prospectId     Int?
  clientId       Int?
  ownerId        Int?
  propertyId     Int?
  conventionId   Int?
  lotissementId  Int?
  terrainId      Int?
  programmeId    Int?
  invoiceId      Int?
  installmentId  Int?
  projectId      Int?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user        User?                @relation(fields: [userId], references: [id])
  prospect    Prospect?            @relation(fields: [prospectId], references: [id])
  client      Client?              @relation(fields: [clientId], references: [id])
  owner       Owner?               @relation(fields: [ownerId], references: [id])
  property    Property?            @relation(fields: [propertyId], references: [id])
  convention  Convention?          @relation(fields: [conventionId], references: [id])
  lotissement Lotissement?         @relation(fields: [lotissementId], references: [id])
  terrain     Terrain?             @relation(fields: [terrainId], references: [id])
  programme   ProgrammeImmobilier? @relation(fields: [programmeId], references: [id])
  invoice     Invoice?             @relation(fields: [invoiceId], references: [id])
  installment SaleInstallment?     @relation(fields: [installmentId], references: [id])
  project     Project?             @relation(fields: [projectId], references: [id])
}

enum ActivityType {
  NOTIFICATION
  APPEL
  EMAIL
  SMS
  REUNION
  VISITE
  TASK
  RAPPEL
  DOCUMENT
}

enum ActivityStatus {
  EN_ATTENTE
  EN_TRAITEMENT
  TRAITE
  ANNULE
}

model Communication {
  id         Int          @id @default(autoincrement())
  channel    CommChannel
  direction  CommDirection @default(SORTANT)
  to         String
  subject    String?
  body       String       @db.Text
  status     CommStatus   @default(EN_ATTENTE)
  sentAt     DateTime?
  errorMsg   String?
  templateId Int?
  metadata   Json?
  createdAt  DateTime     @default(now())

  template CommTemplate? @relation(fields: [templateId], references: [id])
}

model CommTemplate {
  id             Int          @id @default(autoincrement())
  name           String
  channel        CommChannel
  subject        String?
  body           String       @db.Text
  variables      Json?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  communications Communication[]
}

enum CommChannel {
  EMAIL
  SMS
}

enum CommDirection {
  ENTRANT
  SORTANT
}

enum CommStatus {
  EN_ATTENTE
  ENVOYE
  RECU
  ECHEC
  REFUSE
}

// ── DOCUMENTS ─────────────────────────────────────────────────

model Document {
  id             Int          @id @default(autoincrement())
  name           String
  type           String       // Type MIME
  path           String       // Chemin relatif dans le dossier de stockage
  size           Int          // Taille en octets
  category       String?      // Catégorie technique héritée (identité, dm_scan…)
  // ── GED (gestion électronique de documents) ──────────────────
  numeroArchive  String?      @unique  // Numéro d'archive automatique : ARC-AAAA-NNNN
  description    String?      @db.Text
  categoryId     Int?         // Catégorie documentaire (classement)
  folderId       Int?         // Dossier dans l'arborescence documentaire
  uploadedById   Int?         // Utilisateur ayant importé le document
  ocrText        String?      @db.LongText  // Texte extrait par OCR (indexation plein texte)
  isPhysical     Boolean      @default(false)  // Possède une contrepartie papier
  physBureau     String?      // Localisation physique : bureau
  physCarton     String?      // Localisation physique : carton
  physClasseur   String?      // Localisation physique : classeur
  // ── Rattachement aux entités métier ──────────────────────────
  clientId       Int?
  ownerId        Int?
  propertyId     Int?
  conventionId   Int?
  lotissementId  Int?
  terrainId      Int?
  programmeId    Int?
  projectId      Int?
  // Rattachements complémentaires : un document peut être lié à au plus
  // une entité de chaque type (FK nullables, pattern identique aux
  // rattachements ci-dessus).
  prospectId     Int?
  referrerId     Int?         // Apporteur d'affaires (BusinessReferrer)
  linkedUserId   Int?         // Utilisateur rattaché (distinct de uploadedBy)
  invoiceId      Int?
  commissionId   Int?
  attestationId  Int?
  uploadedAt     DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  client           Client?              @relation(fields: [clientId], references: [id])
  owner            Owner?               @relation(fields: [ownerId], references: [id])
  property         Property?            @relation(fields: [propertyId], references: [id])
  convention       Convention?          @relation(fields: [conventionId], references: [id])
  lotissement      Lotissement?         @relation(fields: [lotissementId], references: [id])
  terrain          Terrain?             @relation(fields: [terrainId], references: [id])
  programme        ProgrammeImmobilier? @relation(fields: [programmeId], references: [id])
  project          Project?             @relation(fields: [projectId], references: [id])
  prospect         Prospect?            @relation(fields: [prospectId], references: [id])
  referrer         BusinessReferrer?    @relation("DocumentReferrer", fields: [referrerId], references: [id])
  linkedUser       User?                @relation("DocumentLinkedUser", fields: [linkedUserId], references: [id])
  invoice          Invoice?             @relation(fields: [invoiceId], references: [id])
  commission       Commission?          @relation(fields: [commissionId], references: [id])
  attestation      Attestation?         @relation(fields: [attestationId], references: [id])
  documentCategory DocumentCategory?    @relation(fields: [categoryId], references: [id])
  folder           DocumentFolder?      @relation(fields: [folderId], references: [id])
  uploadedBy       User?                @relation("DocumentUploadedBy", fields: [uploadedById], references: [id])
  tags             DocumentTag[]
  auditLogs        DocumentAuditLog[]
}

// Catégorie documentaire — auto-référencée pour les sous-catégories.
model DocumentCategory {
  id        Int       @id @default(autoincrement())
  name      String
  parentId  Int?
  color     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  parent    DocumentCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  DocumentCategory[] @relation("CategoryTree")
  documents Document[]
}

// Dossier de l'arborescence documentaire — auto-référencé.
model DocumentFolder {
  id        Int       @id @default(autoincrement())
  name      String
  parentId  Int?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  parent    DocumentFolder?  @relation("FolderTree", fields: [parentId], references: [id])
  children  DocumentFolder[] @relation("FolderTree")
  documents Document[]
}

// Étiquette appliquée à un document (jointure réutilisant le modèle Tag).
model DocumentTag {
  documentId Int
  tagId      Int

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([documentId, tagId])
}

// Journal des actions sur les documents (traçabilité).
model DocumentAuditLog {
  id         Int                 @id @default(autoincrement())
  documentId Int?
  action     DocumentAuditAction
  userId     Int?
  detail     String?             @db.Text
  createdAt  DateTime            @default(now())

  document Document? @relation(fields: [documentId], references: [id])
  user     User?     @relation("DocumentAuditUser", fields: [userId], references: [id])
}

enum DocumentAuditAction {
  IMPORT
  CONSULTATION
  MODIFICATION
  SUPPRESSION
  TELECHARGEMENT
  RESTAURATION
}

model Note {
  id         Int      @id @default(autoincrement())
  content    String   @db.Text
  entityType String
  entityId   Int
  userId     Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id])
}

model Tag {
  id    Int    @id @default(autoincrement())
  name  String @unique
  color String?

  prospects ProspectTag[]
  documents DocumentTag[]
}

model ProspectTag {
  prospectId Int
  tagId      Int

  prospect Prospect @relation(fields: [prospectId], references: [id])
  tag      Tag      @relation(fields: [tagId], references: [id])

  @@id([prospectId, tagId])
}

model AppSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

// ── PAYS ──────────────────────────────────────────────────────

/// Table de référence des pays : code ISO 3166-1 alpha-2 et indicatif téléphonique.
model Country {
  id       Int    @id @default(autoincrement())
  isoCode  String @unique  // Code ISO 3166-1 alpha-2 (ex: CI)
  name     String          // Nom du pays en français
  dialCode String          // Indicatif téléphonique international (ex: +225)
}

// ── TYPES DE PIÈCES D'IDENTITÉ ────────────────────────────────

/// Catalogue extensible des types de pièces d'identité (CNI, Passeport,
/// Permis de conduire, etc.). Géré depuis Paramètres › Types de pièces
/// d'identité. Une entrée par défaut (CNI) est créée en seed.
model IdDocumentType {
  id          Int       @id @default(autoincrement())
  code        String    @unique  // Slug stable (ex: CNI, PASSEPORT)
  label       String             // Libellé d'affichage (ex: « Carte Nationale d'Identité (CNI) »)
  isDefault   Boolean   @default(false)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  clients          Client[] @relation("ClientIdType")
  owners           Owner[]  @relation("OwnerIdType")
  ownersLegalReps  Owner[]  @relation("OwnerLegalRepIdType")
}

// ── NATURES DE TITRES DE LOTISSEMENT ──────────────────────────

/// Catalogue extensible des natures de titres administratifs sollicités pour
/// un lotissement (Arrêté d'approbation, Permis d'aménager, etc.). Géré
/// depuis Paramètres › Natures de titres de lotissement. Une entrée par
/// défaut (Arrêté d'approbation) est créée en seed.
model LotissementTitleType {
  id              Int       @id @default(autoincrement())
  code            String    @unique  // Slug stable (ex: ARRETE_APPROBATION)
  label           String             // Libellé d'affichage (ex: « Arrêté d'approbation »)
  /// Libellé des documents administratifs livrés avec les terrains de ce
  /// titre (ex: « ACD, plan de masse, situation géographique »). Substitué
  /// dans les modèles de convention / attestation via la variable
  /// `lotissement.documentsLivres`.
  documentsLivres String?   @db.Text
  isDefault       Boolean   @default(false)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  lotissements Lotissement[]
}

// ── ARCHIVAGE ─────────────────────────────────────────────────

model ArchiveRecord {
  id            Int               @id @default(autoincrement())
  uuid          String            @unique @default(cuid())
  entityType    ArchiveEntityType
  entityId      Int
  entityRef     String
  snapshot      Json
  reason        ArchiveReason     @default(MANUEL)
  reasonDetail  String?           @db.Text
  archivedById  Int?
  archivedAt    DateTime          @default(now())
  restoredById  Int?
  restoredAt    DateTime?
  status        ArchiveStatus     @default(ARCHIVE)
  retentionDate DateTime?
  notes         String?           @db.Text

  archivedBy User? @relation("ArchivedBy", fields: [archivedById], references: [id])
  restoredBy User? @relation("RestoredBy", fields: [restoredById], references: [id])
}

enum ArchiveEntityType {
  CLIENT
  PROSPECT
  OWNER
  PROPERTY
  CONVENTION
  INVOICE
  DOCUMENT
}

enum ArchiveStatus {
  ARCHIVE
  RESTAURE
  SUPPRIME_DEFINITIVEMENT
}

enum ArchiveReason {
  MANUEL
  CONVENTION_TERMINEE
  CLIENT_INACTIF
  BIEN_VENDU
  POLITIQUE_AUTOMATIQUE
  DEMANDE_RGPD
  AUTRE
}

model ArchivePolicy {
  id               Int               @id @default(autoincrement())
  name             String
  description      String?           @db.Text
  entityType       ArchiveEntityType
  triggerCondition Json
  retentionDays    Int?
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

// ── COMMISSIONS ───────────────────────────────────────────────

// Apporteur d'affaire : référent externe (non-utilisateur de l'application)
model BusinessReferrer {
  id          Int       @id @default(autoincrement())
  uuid        String    @unique @default(cuid())
  firstName   String
  lastName    String
  companyName String?
  email       String?
  phone       String?
  mobile      String?
  address     String?
  city        String?
  country     String    @default("CI")
  bankIban    String?
  bankBic     String?
  notes       String?   @db.Text
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  commissions Commission[]
  clients     Client[]     @relation("ClientReferrer")
  documents   Document[]   @relation("DocumentReferrer")
}

model Commission {
  id              Int                       @id @default(autoincrement())
  uuid            String                    @unique @default(cuid())
  reference       String                    @unique  // Ex: COM-2026-0001
  conventionId    Int
  // Bénéficiaire : soit un utilisateur, soit un apporteur d'affaire
  beneficiaryType CommissionBeneficiaryType
  userId          Int?
  referrerId      Int?
  // Calcul de la commission
  transactionType CommissionTransactionType // VENTE ou LOCATION
  baseAmount      Decimal                   @db.Decimal(15, 2)  // Assiette (prix de vente ou loyer)
  rate            Decimal                   @db.Decimal(5, 2)   // Taux en %
  amount          Decimal                   @db.Decimal(15, 2)  // Montant de la commission
  status          CommissionStatus          @default(A_PAYER)
  source          CommissionSource          @default(MANUEL)
  // Paiement
  paidAt          DateTime?
  paymentMethod   PaymentMethod?
  paymentRef      String?                   // Référence du règlement (chèque, virement…)
  paidById        Int?                      // Utilisateur ayant enregistré le paiement
  // Annulation
  cancelledAt     DateTime?
  cancelReason    String?                   @db.Text
  cancelledById   Int?                      // Utilisateur ayant annulé la commission
  notes           String?                   @db.Text
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  deletedAt       DateTime?

  convention  Convention        @relation(fields: [conventionId], references: [id])
  user        User?             @relation("UserCommissions", fields: [userId], references: [id])
  referrer    BusinessReferrer? @relation(fields: [referrerId], references: [id])
  paidBy      User?             @relation("CommissionPaidBy", fields: [paidById], references: [id])
  cancelledBy User?             @relation("CommissionCancelledBy", fields: [cancelledById], references: [id])
  documents   Document[]
}

enum CommissionBeneficiaryType {
  USER       // Utilisateur de l'application (agent, manager…)
  REFERRER   // Apporteur d'affaire externe
}

enum CommissionTransactionType {
  VENTE
  LOCATION
  SOUSCRIPTION
  FRAIS_DOSSIER
}

enum CommissionStatus {
  A_PAYER
  PAYEE
  ANNULEE
}

enum CommissionSource {
  MANUEL       // Commission saisie manuellement
  AUTOMATIQUE  // Commission générée à l'activation de la convention
}

// ── TRÉSORERIE ────────────────────────────────────────────────

// Compte de trésorerie de l'entreprise (banque, caisse espèces ou mobile money).
model BankAccount {
  id             Int                 @id @default(autoincrement())
  uuid           String              @unique @default(cuid())
  name           String              // Libellé du compte (ex: « Compte courant SGBCI »)
  type           TreasuryAccountType @default(BANQUE)
  bankName       String?             // Nom de la banque / opérateur
  accountNumber  String?             // Numéro de compte / RIB
  iban           String?
  bic            String?
  currency       String              @default("XOF")
  initialBalance Decimal             @default(0) @db.Decimal(15, 2)  // Solde d'ouverture
  isActive       Boolean             @default(true)
  notes          String?             @db.Text
  // Compte privé : rattaché à un utilisateur. Hors SUPER_ADMIN/ADMIN, seul cet
  // utilisateur peut consulter le compte et y enregistrer des opérations.
  linkedUserId   Int?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  deletedAt      DateTime?

  linkedUser User?               @relation("BankAccountLinkedUser", fields: [linkedUserId], references: [id])
  operations TreasuryOperation[]
  payments   Payment[]
}

enum TreasuryAccountType {
  BANQUE
  CAISSE
  MOBILE_MONEY
}

// Objet d'opération : nature paramétrable d'une entrée/sortie, rattachée à un
// numéro de compte comptable (ex: 301).
model TreasuryCategory {
  id             Int               @id @default(autoincrement())
  uuid           String            @unique @default(cuid())
  label          String            // Libellé de l'objet (ex: « Encaissement loyer »)
  direction      TreasuryDirection // Sens de l'opération : ENTREE ou SORTIE
  accountingCode String?           // Numéro de compte comptable (ex: « 301 »)
  isActive       Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  deletedAt      DateTime?

  operations TreasuryOperation[]
}

enum TreasuryDirection {
  ENTREE
  SORTIE
}

// Mouvement de trésorerie : entrée ou sortie d'argent sur un compte.
model TreasuryOperation {
  id            Int               @id @default(autoincrement())
  uuid          String            @unique @default(cuid())
  reference     String            @unique  // Ex: OPT-2026-0001
  bankAccountId Int
  direction     TreasuryDirection
  amount        Decimal           @db.Decimal(15, 2)
  operationDate DateTime          @default(now())
  categoryId    Int?              // Objet d'opération
  label         String            // Libellé de l'opération
  paymentMethod PaymentMethod     @default(ESPECE)
  paymentRef    String?           // Référence du règlement (chèque, virement…)
  source        TreasurySource    @default(MANUEL)
  paymentId     Int?              // Paiement de facture rattaché (source FACTURE)
  installmentId Int?              // Échéance de vente rattachée (source ECHEANCE)
  commissionId  Int?              // Commission rattachée (source COMMISSION)
  budgetLineId  Int?              // Ligne budgétaire d'imputation (sorties uniquement)
  // Imputation analytique : une opération peut être rattachée à au plus UNE
  // entité parmi projet / lotissement / programme immobilier. L'exclusivité est
  // appliquée en code (validation Zod côté IPC).
  projectId     Int?              // Projet rattaché
  lotissementId Int?              // Lotissement rattaché
  programmeId   Int?              // Programme immobilier rattaché
  createdById   Int?
  notes         String?           @db.Text
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  deletedAt     DateTime?

  bankAccount BankAccount          @relation(fields: [bankAccountId], references: [id])
  category    TreasuryCategory?    @relation(fields: [categoryId], references: [id])
  createdBy   User?                @relation("TreasuryCreatedBy", fields: [createdById], references: [id])
  budgetLine  BudgetLine?          @relation(fields: [budgetLineId], references: [id])
  project     Project?             @relation(fields: [projectId], references: [id])
  lotissement Lotissement?         @relation(fields: [lotissementId], references: [id])
  programme   ProgrammeImmobilier? @relation(fields: [programmeId], references: [id])
}

enum TreasurySource {
  MANUEL      // Opération saisie manuellement
  FACTURE     // Générée par l'encaissement d'une facture
  ECHEANCE    // Générée par le règlement d'une échéance de vente
  COMMISSION  // Générée par le paiement d'une commission
}

// ── BUDGETS ───────────────────────────────────────────────────

// Budget : enveloppe globale (période, total alloué, statut). Regroupe des
// lignes budgétaires. Lorsqu'il est clôturé, plus aucune opération ne peut être
// imputée à ses lignes et un récapitulatif figé est conservé dans `closingSnapshot`.
model Budget {
  id              Int          @id @default(autoincrement())
  uuid            String       @unique @default(cuid())
  reference       String       @unique  // Ex: BUDG-2026-0001
  name            String
  description     String?      @db.Text
  periodStart     DateTime
  periodEnd       DateTime
  totalAllocated  Decimal?     @db.Decimal(15, 2)  // Optionnel : somme indicative
  status          BudgetStatus @default(OUVERT)
  closingSnapshot Json?        // Récapitulatif figé à la clôture
  closedAt        DateTime?
  closedById      Int?
  notes           String?      @db.Text
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  deletedAt       DateTime?

  closedBy User?        @relation("BudgetClosedBy", fields: [closedById], references: [id])
  lines    BudgetLine[]
}

enum BudgetStatus {
  OUVERT
  CLOTURE
}

// Ligne budgétaire : poste de dépense rattaché à un budget. Gérée par un
// utilisateur (`managerId`, qui ne peut pas être un ADMIN ou un SUPER_ADMIN) ;
// seul ce gestionnaire — ou un ADMIN/SUPER_ADMIN — peut y imputer une opération
// de sortie de trésorerie.
model BudgetLine {
  id              Int       @id @default(autoincrement())
  uuid            String    @unique @default(cuid())
  budgetId        Int
  code            String?   // Code court optionnel (ex: BL-001)
  label           String
  description     String?   @db.Text
  allocatedAmount Decimal   @db.Decimal(15, 2)
  managerId       Int?
  isActive        Boolean   @default(true)
  notes           String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  budget     Budget              @relation(fields: [budgetId], references: [id])
  manager    User?               @relation("BudgetLineManager", fields: [managerId], references: [id])
  operations TreasuryOperation[]
}

// ── PROJETS ───────────────────────────────────────────────────

// Catalogue extensible des types de projets (Construction de bâtiments,
// Bornage, Bitumage, etc.). Géré depuis Paramètres › Types de projets.
model ProjectType {
  id          Int       @id @default(autoincrement())
  code        String    @unique  // Slug stable (ex: CONSTRUCTION_BATIMENTS)
  label       String             // Libellé d'affichage
  description String?   @db.Text
  color       String?            // Couleur hex (ex: #2563EB)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  projects Project[]
}

// Projet : opération supervisée par l'agence (construction, ouverture de
// voies, bornage, bitumage…). Référence auto PROJ-YYYY-NNNN. Rattachements
// optionnels : client commanditaire, propriétaire, terrain, lotissement,
// programme immobilier.
model Project {
  id              Int           @id @default(autoincrement())
  uuid            String        @unique @default(cuid())
  reference       String        @unique // Ex: PROJ-2026-0001
  nom             String
  typeId          Int           // Type de projet (obligatoire)
  statut          ProjectStatus @default(EN_PROJET)
  // Rattachements optionnels
  clientId        Int?
  ownerId         Int?
  terrainId       Int?
  lotissementId   Int?
  programmeId     Int?
  // Localisation
  adresse         String?
  commune         String?
  quartier        String?
  ville           String?
  pays            String        @default("CI")
  latitude        Float?
  longitude       Float?
  // Dates & avancement
  dateDebutPrevu  DateTime?
  dateDebutReel   DateTime?
  dateFinPrevue   DateTime?
  dateFinReelle   DateTime?
  avancement      Int           @default(0) // Taux d'avancement 0–100 %
  // Financier
  budgetPrevu     Decimal?      @db.Decimal(15, 2)
  budgetRealise   Decimal?      @db.Decimal(15, 2)
  // Description
  description     String?       @db.Text
  notes           String?       @db.Text
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  type        ProjectType          @relation(fields: [typeId], references: [id])
  client      Client?              @relation(fields: [clientId], references: [id])
  owner       Owner?               @relation(fields: [ownerId], references: [id])
  terrain     Terrain?             @relation(fields: [terrainId], references: [id])
  lotissement Lotissement?         @relation(fields: [lotissementId], references: [id])
  programme   ProgrammeImmobilier? @relation(fields: [programmeId], references: [id])
  photos      ProjectPhoto[]
  documents   Document[]
  activities  CrmActivity[]
  treasuryOperations TreasuryOperation[]
}

enum ProjectStatus {
  EN_PROJET
  EN_COURS
  SUSPENDU
  TERMINE
  ANNULE
}

model ProjectPhoto {
  id        Int      @id @default(autoincrement())
  projectId Int
  path      String
  caption   String?
  isPrimary Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])
}
